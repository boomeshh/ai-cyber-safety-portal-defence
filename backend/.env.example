# Rakshak AI — Environment Configuration
# Copy this file to .env and fill in your values

# Email alerts (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_TO=admin@rakshak.ai,cert@rakshak.ai

# VirusTotal URL threat intelligence (optional)
VT_ENABLED=false
VT_API_KEY=your-virustotal-api-key
