# Rakshak AI — Environment Configuration
# Copy this file to .env and fill in your values

# ── Resend email alerts (recommended — works on Render free plan) ──────────
RESEND_ENABLED=false
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=Rakshak AI <alerts@yourdomain.com>
RESEND_ALERT_TO=admin@example.com,cert@example.com

# ── SMTP email alerts (fallback — may fail on Render free plan) ───────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_TO=admin@rakshak.ai,cert@rakshak.ai

# ── VirusTotal URL threat intelligence (optional) ─────────────────────────
VT_ENABLED=false
VT_API_KEY=your-virustotal-api-key
